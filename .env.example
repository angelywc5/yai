# App
APP_NAME=YAI
DEBUG=true
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://yai:yai@localhost:5432/yai
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_STATEMENT_TIMEOUT=30000

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=20160

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_SPEED_MODEL=gemini-3-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_ELITE_MODEL=gemini-3.1-pro
GEMINI_REQUEST_TIMEOUT=30
GEMINI_EMBEDDING_MODEL=text-embedding-004

# SMTP
SMTP_PROVIDER=resend
SMTP_API_KEY=your-resend-api-key
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM_EMAIL=noreply@yai.app
VERIFICATION_URL_BASE=http://localhost:3000/verify
VERIFICATION_TOKEN_EXPIRE_HOURS=24

# Admin
ADMIN_EMAIL_ALLOWLIST=["ops@yai.app","founder@yai.app"]
ADMIN_AUTO_PROMOTE_ON_VERIFY=true
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_TOKEN=

# Credits
DEFAULT_CREDITS=500
SPEED_CREDITS_PER_1K_TOKENS=10
PRO_CREDITS_PER_1K_TOKENS=50
ELITE_CREDITS_PER_1K_TOKENS=150
CREDIT_HOLD_MULTIPLIER=1.5
CREDIT_HOLD_DEFAULT_TOKENS=1000

# Memory
MAX_SHORT_TERM_MESSAGES=20
MAX_LONG_TERM_FRAGMENTS=5
MAX_STORY_SUMMARIES=3
CHAT_HISTORY_INITIAL_ROUNDS=20
CHAT_HISTORY_PAGE_ROUNDS=20
EMBEDDING_DIMENSION=768
EMBEDDING_PROVIDER=gemini
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Story Summary & Response Length
SUMMARY_TRIGGER_INTERVAL=10
SUMMARY_MAX_KEY_DIALOGUES=5
SUMMARY_MODEL_TIER=speed
SUMMARY_MAX_LENGTH=200
CHAT_RESPONSE_TARGET_TOKENS=800
CHAT_RESPONSE_HARD_CAP_TOKENS=1200

# Rate Limiting
RATE_LIMIT_CHAT_MAX=10
RATE_LIMIT_CHAT_WINDOW=60
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=60
RATE_LIMIT_UPLOAD_MAX=20
RATE_LIMIT_UPLOAD_WINDOW=3600
RATE_LIMIT_DEFAULT_MAX=60
RATE_LIMIT_DEFAULT_WINDOW=60

# Scene
MAX_SCENE_CHARACTERS=10
MAX_SCENE_DEFINITION_LENGTH=5000
MAX_SCENE_GREETING_LENGTH=2000
MAX_SCENE_METADATA_LENGTH=100
MAX_SCENE_TAGS=10
MAX_SCENE_PLAYER_OBJECTIVE_LENGTH=1000

# Upload
UPLOAD_DIR=static/uploads
MAX_UPLOAD_SIZE_MB=5
AVATAR_RESIZE_PX=256
COVER_RESIZE_WIDTH=800
COVER_RESIZE_HEIGHT=450
DEFAULT_AVATARS_DIR=static/defaults/avatars
DEFAULT_COVERS_DIR=static/defaults/covers

# Message & Customization
MAX_PINNED_MESSAGES_PER_CHARACTER=20
MAX_CUSTOM_PROMPT_LENGTH=2000
MAX_TAGS_PER_CHARACTER=10
MAX_TAG_LENGTH=20
RECENT_CHARACTERS_LIMIT=20
SESSION_PREVIEW_LENGTH=100
USERNAME_MIN_LENGTH=2
USERNAME_MAX_LENGTH=30
